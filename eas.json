{
  "cli": {
    "version": ">= 18.0.4",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "env": {
          "ANDROID_TARGET_SDK_VERSION": "35",
          "ANDROID_COMPILE_SDK_VERSION": "35",
          "ANDROID_BUILD_TOOLS_VERSION": "35.0.0"
        }
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759629554"
      }
    }
  }
}
