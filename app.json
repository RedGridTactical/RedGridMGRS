{
  "expo": {
    "name": "RedGrid Tactical",
    "slug": "redgrid-tactical",
    "version": "2.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.redgrid.redgridtactical",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.redgrid.redgridtactical",
      "buildNumber": "2",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RedGrid Tactical uses your location to display your current grid coordinates. No location data is stored or transmitted.",
        "SKAdNetworkItems": []
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RedGrid Tactical uses your location to display your current grid coordinates. No data is stored or transmitted."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c55caaee-6950-4b8c-850b-f0d2d402cc09"
      }
    }
  }
}